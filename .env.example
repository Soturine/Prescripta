# Backend
PRESCRIPTA_ENV=development
PRESCRIPTA_DATABASE_URL=sqlite:///./prescripta.db
PRESCRIPTA_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PRESCRIPTA_SECRET_KEY=change-this-demo-secret-before-production
PRESCRIPTA_ACCESS_TOKEN_EXPIRE_MINUTES=60
PRESCRIPTA_CONFIG_ENCRYPTION_KEY=

# AI provider defaults
PRESCRIPTA_AI_PROVIDER=fallback
PRESCRIPTA_AI_MODEL=
PRESCRIPTA_AI_BASE_URL=
PRESCRIPTA_AI_TIMEOUT_SECONDS=30
PRESCRIPTA_AI_TEMPERATURE=0.2
PRESCRIPTA_AI_MAX_OUTPUT_TOKENS=900
PRESCRIPTA_AI_ENABLE_EXTERNAL_CALLS=false
PRESCRIPTA_AI_USE_JSON_MODE=true

# Reports use the active AI provider only when external calls are enabled.
# Evidence bundles sent to external AI are minimized by default.

# Provider-specific keys, optional if configured via UI
PRESCRIPTA_AI_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=

# Frontend
VITE_API_URL=http://localhost:8000/api
